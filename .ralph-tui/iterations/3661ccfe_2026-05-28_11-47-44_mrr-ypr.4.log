// fetchReviewerSourceREST is the REST fallback for reviewer-requested MRs.
func (a *GitLabAdapter) fetchReviewerSourceREST(
	ctx context.Context,
	username string,
	logger *slog.Logger,
	start time.Time,
) sourceResult {
	mrs, err := a.client.ListReviewerMRs(ctx, username)
	if err != nil {
		logger.Error("gitlab: list reviewer MRs failed (REST)", "username", username, "error", err)
		return sourceResult{errs: []error{fmt.Errorf("reviewer user=%q: %w", username, err)}}
	}
	var active []*gl.BasicMergeRequest
	var errs []error
	for _, mr := range mrs {
		archived, err := a.client.IsProjectArchived(ctx, mr.ProjectID)
		if err != nil {
			logger.Error("gitlab: check project archived failed",
				"reviewer", username, "mr", mr.IID, "project", mr.ProjectID, "error", err)
			errs = append(errs, fmt.Errorf("reviewer user=%q MR=%d: %w", username, mr.IID, err))
			continue
		}
		if !archived {
			active = append(active, mr)
		} else {
			logger.Debug("gitlab: skipping reviewer MR from archived project (REST)", "iid", mr.IID, "project", mr.ProjectID)
		}
	}
	logger.Info("gitlab: reviewer source fetched (REST fallback)",
		"username", username, "total", len(mrs), "active", len(active),
		"duration", ilog.FmtDur(time.Since(start)))
	return sourceResult{raw: active, errs: errs}
}
